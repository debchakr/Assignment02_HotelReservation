<configuration>
    <springProperty scope="context" name="loglevelKlm" source="logging.level.com.klm"/>
    <springProperty scope="context" name="loglevelRoot" source="logging.level.root"/>

    <appender name="CONSOLE_LOCAL" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] - [%X{traceId:-}] - %-5level %logger %ex{short} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="com.klm" level="${loglevelKlm}"/>

    <root level="${loglevelRoot}" additivity="false">
        <appender-ref ref="CONSOLE_LOCAL" />
    </root>
</configuration>